// prisma/schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"  // 关系由 Prisma 管理，不创建数据库外键约束
}

// 租户
model Company {
  id           Int      @id @default(autoincrement())
  uuid         String   @unique @default(uuid())
  name         String
  // 邮箱域名匹配（用于登录时识别 Company）
  emailDomains String[] @default([])  // e.g., ["example.com", "example.org"]
  // OIDC 配置（每个 Company 独立的登录方式，仅支持 PKCE，无需 Client Secret）
  oidcIssuer   String?  // OIDC Provider URL
  oidcClientId String?  // Client ID
  oidcEnabled  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users      User[]
  agents     Agent[]
  apiKeys    ApiKey[]
  projects   Project[]
  ideas      Idea[]
  documents  Document[]
  tasks      Task[]
  proposals  Proposal[]
  activities Activity[]
  comments   Comment[]
  sessions   AgentSession[]
}

// 用户（人类，OIDC 登录）
model User {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  companyUuid String
  company     Company  @relation(fields: [companyUuid], references: [uuid])
  oidcSub     String   @unique    // OIDC subject
  email       String?
  name        String?
  avatarUrl   String?
  createdAt   DateTime @default(now())

  ownedAgents Agent[]

  @@index([companyUuid])
}

// Agent（Claude Code 等）
model Agent {
  id           Int       @id @default(autoincrement())
  uuid         String    @unique @default(uuid())
  companyUuid  String
  company      Company   @relation(fields: [companyUuid], references: [uuid])
  name         String
  roles        String[]  @default(["developer"])  // pm | developer（可多选）
  // Agent 人格定义（Zero Context Injection）
  persona      String?   // 自定义人格描述（简短）
  systemPrompt String?   // 完整系统提示（可选，覆盖默认模板）
  ownerUuid    String?   // User's UUID
  owner        User?     @relation(fields: [ownerUuid], references: [uuid])
  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())

  apiKeys  ApiKey[]
  sessions AgentSession[]

  @@index([companyUuid])
  @@index([ownerUuid])
}

// API Key（独立管理，支持轮换和撤销）
model ApiKey {
  id          Int       @id @default(autoincrement())
  uuid        String    @unique @default(uuid())
  companyUuid String
  company     Company   @relation(fields: [companyUuid], references: [uuid])
  agentUuid   String    // Agent's UUID
  agent       Agent     @relation(fields: [agentUuid], references: [uuid], onDelete: Cascade)
  keyHash     String    @unique    // API Key 哈希存储
  keyPrefix   String               // Key 前缀，用于显示（如 "cho_xxx..."）
  name        String?              // 可选的描述名称
  lastUsed    DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([companyUuid])
  @@index([agentUuid])
}

// 项目
model Project {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  companyUuid String
  company     Company  @relation(fields: [companyUuid], references: [uuid])
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ideas      Idea[]
  documents  Document[]
  tasks      Task[]
  proposals  Proposal[]
  activities Activity[]

  @@index([companyUuid])
}

// 想法（人类原始输入）
model Idea {
  id             Int       @id @default(autoincrement())
  uuid           String    @unique @default(uuid())
  companyUuid    String
  company        Company   @relation(fields: [companyUuid], references: [uuid])
  projectUuid    String
  project        Project   @relation(fields: [projectUuid], references: [uuid], onDelete: Cascade)
  title          String
  content        String?   // 文本内容
  attachments    Json?     // 附件列表 [{type, url, name}]
  // 状态和认领 (ARCHITECTURE.md §7.3)
  status         String    @default("open")  // open | assigned | in_progress | pending_review | completed | closed
  assigneeType   String?   // user | agent
  assigneeUuid   String?   // User or Agent UUID (polymorphic)
  assignedAt     DateTime? // 认领时间
  assignedByUuid String?   // User UUID (human assignment)
  createdByUuid  String    // User UUID
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([companyUuid])
  @@index([projectUuid])
  @@index([status])
  @@index([assigneeUuid])
}

// 文档（PRD、技术设计等，Proposal 产物）
model Document {
  id            Int       @id @default(autoincrement())
  uuid          String    @unique @default(uuid())
  companyUuid   String
  company       Company   @relation(fields: [companyUuid], references: [uuid])
  projectUuid   String
  project       Project   @relation(fields: [projectUuid], references: [uuid], onDelete: Cascade)
  type          String    // prd | tech_design | adr | ...
  title         String
  content       String?   // Markdown 内容
  version       Int       @default(1)
  proposalUuid  String?   // Source Proposal UUID (traceable)
  createdByUuid String    // User or Agent UUID
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([companyUuid])
  @@index([projectUuid])
  @@index([proposalUuid])
}

// 任务（Proposal 产物或人工创建）
model Task {
  id             Int       @id @default(autoincrement())
  uuid           String    @unique @default(uuid())
  companyUuid    String
  company        Company   @relation(fields: [companyUuid], references: [uuid])
  projectUuid    String
  project        Project   @relation(fields: [projectUuid], references: [uuid], onDelete: Cascade)
  title          String
  description    String?
  // 状态和认领 (ARCHITECTURE.md §7.2)
  status         String    @default("open")  // open | assigned | in_progress | to_verify | done | closed
  priority       String    @default("medium") // low | medium | high
  storyPoints    Float?    // 工作量估算（单位：Agent 小时）
  acceptanceCriteria String? // 验收标准（Markdown 格式）
  assigneeType   String?   // user | agent
  assigneeUuid   String?   // User or Agent UUID (polymorphic)
  assignedAt     DateTime? // 认领时间
  assignedByUuid String?   // User UUID (human assignment)
  proposalUuid   String?   // Source Proposal UUID (traceable, optional)
  createdByUuid  String    // User or Agent UUID
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // 任务依赖关系（DAG）
  dependsOn        TaskDependency[] @relation("taskDependencies")
  dependedBy       TaskDependency[] @relation("taskDependedBy")
  // Session checkins
  sessionCheckins  SessionTaskCheckin[]

  @@index([companyUuid])
  @@index([projectUuid])
  @@index([proposalUuid])
  @@index([assigneeUuid])
  @@index([status])
}

// 任务依赖关系（DAG 边）
model TaskDependency {
  id            Int      @id @default(autoincrement())
  taskUuid      String
  dependsOnUuid String
  task          Task     @relation("taskDependencies", fields: [taskUuid], references: [uuid], onDelete: Cascade)
  dependsOn     Task     @relation("taskDependedBy", fields: [dependsOnUuid], references: [uuid], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([taskUuid, dependsOnUuid])
  @@index([taskUuid])
  @@index([dependsOnUuid])
}

// 提议（容器模型：Agent/人类创建，人类审批，包含文档草稿和任务列表）
model Proposal {
  id              Int       @id @default(autoincrement())
  uuid            String    @unique @default(uuid())
  companyUuid     String
  company         Company   @relation(fields: [companyUuid], references: [uuid])
  projectUuid     String
  project         Project   @relation(fields: [projectUuid], references: [uuid], onDelete: Cascade)
  title           String
  description     String?

  // 输入来源（Proposal 基于什么创建）
  inputType       String    // idea | document
  inputUuids      Json      // Array of UUID strings

  // 容器内容（可同时包含文档和任务）
  documentDrafts  Json?     // 文档草稿列表 [{type, title, content}]
  taskDrafts      Json?     // 任务草稿列表 [{title, description, storyPoints, priority, acceptanceCriteria}]

  // 状态与审批
  status          String    @default("draft")  // draft | pending | approved | rejected | revised
  createdByUuid   String    // Agent or User UUID
  createdByType   String    @default("agent") // agent | user
  reviewedByUuid  String?   // User UUID
  reviewNote      String?   // 审批备注
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyUuid])
  @@index([projectUuid])
  @@index([status])
}

// 评论（可以评论 Idea、Proposal、Task、Document）
model Comment {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  companyUuid String
  company     Company  @relation(fields: [companyUuid], references: [uuid])
  targetType  String   // idea | proposal | task | document
  targetUuid  String   // UUID of target entity (idea/proposal/task/document)
  content     String
  authorType  String   // user | agent
  authorUuid  String   // User or Agent UUID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyUuid])
  @@index([targetType, targetUuid])
}

// 活动流（项目级）- 通用设计
model Activity {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  companyUuid String
  company     Company  @relation(fields: [companyUuid], references: [uuid])
  projectUuid String
  project     Project  @relation(fields: [projectUuid], references: [uuid], onDelete: Cascade)
  // 目标实体（通用设计）
  targetType  String   // idea | task | proposal | document
  targetUuid  String   // 目标实体 UUID
  // 操作信息
  actorType   String   // user | agent
  actorUuid   String   // 操作者 UUID
  action      String   // created | assigned | released | status_changed | submitted | approved | rejected | comment_added
  value       Json?    // 操作结果值（如新状态、分配目标信息等）
  // Session 归属（反范式化，避免 join）
  sessionUuid String?
  sessionName String?
  createdAt   DateTime @default(now())

  @@index([companyUuid])
  @@index([projectUuid])
  @@index([targetType, targetUuid])
  @@index([createdAt])
}

// Agent Session（子会话，用于 swarm 模式可观测性）
model AgentSession {
  id              Int       @id @default(autoincrement())
  uuid            String    @unique @default(uuid())
  companyUuid     String
  company         Company   @relation(fields: [companyUuid], references: [uuid])
  agentUuid       String
  agent           Agent     @relation(fields: [agentUuid], references: [uuid], onDelete: Cascade)
  name            String
  description     String?
  status          String    @default("active")  // active | inactive | closed
  lastActiveAt    DateTime  @default(now())
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  taskCheckins    SessionTaskCheckin[]

  @@index([companyUuid])
  @@index([agentUuid])
  @@index([status])
}

// Session-Task 签到关系（多对多）
model SessionTaskCheckin {
  id              Int           @id @default(autoincrement())
  sessionUuid     String
  session         AgentSession  @relation(fields: [sessionUuid], references: [uuid], onDelete: Cascade)
  taskUuid        String
  task            Task          @relation(fields: [taskUuid], references: [uuid], onDelete: Cascade)
  checkinAt       DateTime      @default(now())
  checkoutAt      DateTime?

  @@unique([sessionUuid, taskUuid])
  @@index([sessionUuid])
  @@index([taskUuid])
}

// 通知
model Notification {
  id              Int       @id @default(autoincrement())
  uuid            String    @unique @default(uuid())
  companyUuid     String
  projectUuid     String
  // 接收者（多态：user | agent）
  recipientType   String    // user | agent
  recipientUuid   String
  // 关联实体
  entityType      String    // task | idea | proposal | document | comment
  entityUuid      String
  entityTitle     String    // 反范式化，避免 join
  projectName     String    // 反范式化，用于项目徽章 UI
  // 操作信息
  action          String    // assigned | status_changed | verified | reopened | submitted | approved | rejected | claimed | comment_added
  message         String    // 人类可读消息
  actorType       String    // user | agent
  actorUuid       String
  actorName       String    // 反范式化，避免 join
  // 状态
  readAt          DateTime?
  archivedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([recipientType, recipientUuid, readAt])
  @@index([companyUuid, recipientUuid])
  @@index([entityType, entityUuid])
  @@index([projectUuid])
}

// 通知偏好设置
model NotificationPreference {
  id                  Int      @id @default(autoincrement())
  uuid                String   @unique @default(uuid())
  companyUuid         String
  ownerType           String   // user | agent
  ownerUuid           String
  // 各通知类型开关（默认全部开启）
  taskAssigned        Boolean  @default(true)
  taskStatusChanged   Boolean  @default(true)
  taskVerified        Boolean  @default(true)
  taskReopened        Boolean  @default(true)
  proposalSubmitted   Boolean  @default(true)
  proposalApproved    Boolean  @default(true)
  proposalRejected    Boolean  @default(true)
  ideaClaimed         Boolean  @default(true)
  commentAdded        Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([ownerType, ownerUuid])
  @@index([companyUuid])
}
